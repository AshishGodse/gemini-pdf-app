# Environment Configuration

# Backend Services
BACKEND_PORT=5000
BACKEND_ENV=development
BACKEND_LOG_LEVEL=debug

# Python Agent
PYTHON_AGENT_PORT=8000
PYTHON_AGENT_HOST=python-agent

# Database
MONGODB_URI=mongodb://mongo:27017/pdf_accessibility
MONGODB_USER=root
MONGODB_PASSWORD=root123

# S3 / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=pdf-bucket
S3_ENDPOINT=http://localstack:4566
S3_USE_SSL=false
# For production, comment out S3_ENDPOINT and set ENVIRONMENT=production

# Redis (optional, for job queues)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend
REACT_APP_API_URL=http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# Node Env
NODE_ENV=development

# Application Settings
SCAN_TIMEOUT_SECONDS=300
MAX_PDF_SIZE_MB=50
RETENTION_DAYS=90
ENVIRONMENT=development
